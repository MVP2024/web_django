<+>contacts.html<!DOCTYPE html>\r\n<html lang=\"ru\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>Категория 1 - Прототип</title>\r\n    <!-- Подключение Bootstrap CSS из локальных файлов -->\r\n    <link href=\"/static/css/bootstrap.min.css\" rel=\"stylesheet\">\r\n    <style>\r\n        /* Опциональные стили для бокового меню, чтобы оно занимало всю высоту */\r\n        .sidebar {\r\n            height: 100vh; /* Высота на весь экран */\r\n            background-color: #343a40;\r\n            color: white;\r\n            padding-top: 1rem;\r\n            position: relative; /* Добавлено для правильного позиционирования .user-info */\r\n            display: flex; /* Используем flexbox для расположения элементов внутри сайдбара */\r\n            flex-direction: column; /* Элементы располагаются вертикально */\r\n        }\r\n\r\n\r\n        /* Стили для выпадающего меню пользователя */\r\n        .dropdown-menu-dark {\r\n            /* Переопределяем цвет фона для более светлого оттенка серого */\r\n            background-color: #495057 !important; /* Используйте !important для гарантированного переопределения */\r\n            border-color: #495057 !important; /* Также можно изменить цвет границы */\r\n        }\r\n\r\n\r\n        .sidebar .sidebar-header {\r\n            padding: 0 1rem 1rem 1rem; /* Отступы для заголовка */\r\n            border-bottom: 1px solid #495057; /* Разделитель под заголовком */\r\n            margin-bottom: 1rem; /* Отступ после заголовка */\r\n        }\r\n\r\n        .sidebar .nav {\r\n             flex-grow: 1; /* Меню занимает все доступное пространство */\r\n             padding: 0 1rem; /* Горизонтальные отступы для меню */\r\n        }\r\n\r\n\r\n        .sidebar .nav-link {\r\n            color: #adb5bd; /* Цвет ссылок */\r\n        }\r\n\r\n        .sidebar .nav-link.active {\r\n            color: #ffffff;\r\n            background-color: blue; /* Цвет основной ссылки */\r\n            border-radius: 0.25rem; /* Небольшое закругление */\r\n        }\r\n\r\n        .sidebar .user-info {\r\n            width: 100%; /* Убеждаемся, что занимает всю ширину */\r\n            padding: 1rem; /* Добавляем внутренние отступы */\r\n            border-top: 1px solid #495057; /* Разделитель теперь на верхнем краю этого блока */\r\n            color: #adb5bd;\r\n            margin-top: auto; /* Прижимает блок пользователя к низу во flex контейнере */\r\n        }\r\n\r\n        \r\n        .main-content {\r\n            padding: 2rem 2rem 2rem 4rem; /* Увеличен левый отступ (4rem) */\r\n            margin-top: 4rem; /* добавляем верхний отступ */\r\n        }\r\n\r\n        \r\n        /* Стили для ограничения ширины карточек в основном содержимом */\r\n        .main-content .card {\r\n            max-width: 300px; /* Максимальная ширина карточки */\r\n            margin-left: auto; /* Центрирование карточки в колонке */\r\n            margin-right: auto; /* Центрирование карточки в колонке */\r\n            margin-top: 6rem; /* Добавляем верхний отступ от заголовка */\r\n        }\r\n\r\n\r\n        .card {\r\n            margin-bottom: 0.5rem; /* Отступ между карточками */\r\n            background-color: #ffffff; /* Установим белый фон для карточек */\r\n            border: 1px solid #e0e0e0; /* Добавим светлую границу */\r\n            box-shadow: 0 2px 5px rgba(0,0,0,0.1); /* Добавим легкую тень */\r\n            border-radius: 0.5rem; /* Скруглим углы */\r\n            overflow: hidden; /* Скрываем все, что выходит за границы скругленных углов */\r\n        }\r\n\r\n        /* Убедимся, что изображение в карточке не выходит за границы */\r\n        .card-img-top {\r\n            width: 100%;\r\n            height: auto;\r\n            /* Скругление углов теперь управляется overflow: hidden; на .card */\r\n            /* border-top-left-radius: calc(0.5rem - 1px); */\r\n            /* border-top-right-radius: calc(0.5rem - 1px); */\r\n        }\r\n\r\n        /* Стиль для блока с заголовком товара */\r\n        .card-title-area {\r\n            border-bottom: 1px solid #e0e0e0; /* Разделительная линия */\r\n            padding: 0.5rem 1.25rem; /* Отступы как у card-header */\r\n            background-color: rgba(0,0,0,.03);\r\n        }\r\n\r\n         .card-title-area h5 {\r\n             margin-bottom: 0; /* Убираем нижний отступ у заголовка внутри блока */\r\n         }\r\n\r\n         .card-body {\r\n             padding-top: 1rem; /* Уменьшен верхний отступ */\r\n             padding-bottom: 1rem; /* Добавлен нижний отступ */\r\n             flex-grow: 1; /* Позволяем card-body занимать доступное пространство */\r\n             display: flex; /* Используем flexbox внутри card-body */\r\n             flex-direction: column; /* Элементы располагаются вертикально */\r\n             justify-content: space-between; /* Распределяем пространство между элементами */\r\n             align-items: center; /* Центрируем содержимое по горизонтали */\r\n         }\r\n\r\n         .card-body .card-text:last-child {\r\n             margin-bottom: 1.5rem; /* Увеличим отступ перед кнопкой */\r\n         }\r\n\r\n         /* Стили для кнопки \"Купить\" */\r\n         .card-body .btn-outline-primary {\r\n             /* Bootstrap по умолчанию делает outline кнопку, но можем добавить свои корректировки */\r\n             border-color: blue; /* Цвет рамки */\r\n             color: blue; /* Цвет текста */\r\n             background-color: transparent; /* Прозрачный фон */\r\n             border-radius: 0.25rem; /* Скругление углов */\r\n         }\r\n\r\n         .card-body .btn-outline-primary:hover {\r\n             color: wheat; /* Цвет текста при наведении */\r\n             background-color: blue; /* Цвет фона при наведении */\r\n             border-color: blue; /* Цвет рамки при наведении */\r\n         }\r\n\r\n\r\n    </style>\r\n</head>\r\n<body>\r\n\r\n<div class=\"container